{
  "logging": {
    "enabled": true,
    "minimumLevel": "Debug",
    "includeStackTraces": false
  },
  "cache": {
    "defaultCacheSize": 50
  },
  "plugins": {
    "scanDirectories": ["./plugins"],
    "assemblies": [
      "./Sensemation.Core.Acquisition.Source.Memory.dll",
      "./Sensemation.Core.Acquisition.Adapter.WebApi.dll",
      "./Sensemation.Core.Acquisition.Trigger.Time.dll"
    ]
  },
  "sources": [
    {
      "id": "memory-1",
      "type": "memory",
      "parameters": []
    }
  ],
  "triggers": [
    {
      "id": "fast",
      "type": "time",
      "parameters": [
        {
          "name": "updaterate",
          "value": "1000"
        }
      ]
    }
  ],
  "groups": [
    {
      "id": "demo-group",
      "source": "memory-1",
      "trigger": "fast",
      "staleThresholdSeconds": 600
    }
  ],
  "items": [
    {
      "sourceAddress": "tag1",
      "id": "tag1",
      "group": "demo-group",
      "datatype": "Integer32",
      "cacheSize": 100,
      "adapters": ["webapi"]
    },
    {
      "sourceAddress": "tag2",
      "id": "tag2",
      "group": "demo-group",
      "datatype": "DoublePrecision",
      "cacheSize": 50,
      "adapters": ["webapi"]
    }
  ],
  "adapters": [
    {
      "id": "webapi",
      "type": "webapi",
      "parameters": []
    }
  ]
}